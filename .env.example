# SecureWatch Environment Configuration Template
# Copy this file to .env and adjust the values for your deployment.

# Flask settings
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=False

# Security
# Generate a strong secret key for production, e.g. using `python -c "import secrets; print(secrets.token_hex(24))"`
SECRET_KEY=replace-this-with-a-secure-random-string

# Logging
LOG_LEVEL=INFO
